# --- Database ---
# Local (Laragon)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=grammar_police
MYSQL_SSL=false

# Aiven (uncomment + adjust)
# MYSQL_HOST=grammarpolice-db-xxxx.h.aivencloud.com
# MYSQL_PORT=12792
# MYSQL_USER=avnadmin
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=defaultdb
# MYSQL_SSL=true
# MYSQL_CA_PATH=certs/aiven-ca.pem

# --- AI Provider ---
# "gemini" (default) or "deepseek"
LLM_PROVIDER=gemini

# Gemini API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# DeepSeek API key: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=
